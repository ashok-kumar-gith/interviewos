# InterviewOS backend — example environment configuration.
# Copy to .env for local development. NEVER commit real secrets.

# HTTP port the API listens on.
PORT=8080

# Deployment environment: development | staging | production.
ENV=development

# Log level: debug | info | warn | error.
LOG_LEVEL=info

# PostgreSQL connection URL (system of record).
DATABASE_URL=postgres://interviewos:interviewos@localhost:5432/interviewos?sslmode=disable

# Redis connection URL (cache / sessions / rate-limit).
REDIS_URL=redis://localhost:6379/0

# JWT signing secret for access/refresh tokens.
# Required outside development; generate a long random value for staging/prod.
JWT_SECRET=dev-only-change-me

# Comma-separated CORS origin allowlist (browser origins permitted to call the API).
CORS_ORIGINS=http://localhost:3000

# --- Security hardening (NFR-SEC) ---
# bcrypt work factor for new password hashes. Minimum (and default) is 12;
# lower values are clamped up to 12. Existing hashes verify at their own cost.
BCRYPT_COST=12

# Rate limits (requests per minute). General is per-IP across all /api/v1;
# USER is per-authenticated-user (keyed by user id, falling back to IP); AUTH is
# the stricter per-IP budget on credential-sensitive auth endpoints.
RATE_LIMIT_PER_MIN=60
USER_RATE_LIMIT_PER_MIN=120
AUTH_RATE_LIMIT_PER_MIN=10
